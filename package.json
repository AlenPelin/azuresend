{
  "name": "azuresend",
  "version": "1.0.2",
  "description": "Upload a file to Azure Blob Storage with a timestamped name and print a SAS URL.",
  "bin": {
    "azuresend": "bin/azuresend.js"
  },
  "main": "bin/azuresend.js",
  "scripts": {
    "start": "node bin/azuresend.js",
    "build": "node --check bin/azuresend.js",
    "package": "pkg . --compress GZip",
    "package:win": "pkg . --targets node18-win-x64 --output dist/azuresend.exe --compress GZip"
  },
  "engines": {
    "node": ">=16"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.17.0",
    "cli-progress": "^3.12.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "scripts": [
      "bin/azuresend.js"
    ],
    "targets": [
      "node18-win-x64",
      "node18-linux-x64",
      "node18-macos-x64"
    ],
    "outputPath": "dist"
  },
  "license": "MIT"
}
